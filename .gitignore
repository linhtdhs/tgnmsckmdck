# Dependency directories
node_modules/
**/node_modules/

# Local media storage (downloaded MP3s)
data/media/*
!data/media/.gitkeep

# Local SQLite databases and temp files
data/*.sqlite
data/*.sqlite-journal
data/*.sqlite-wal
data/*.sqlite-shm

# Angular compiled assets and cache
client/dist/
client/.angular/

# .NET compiled outputs and cache
server/bin/
server/obj/
*.user

# Downloaded yt-dlp binaries
bin/yt-dlp*

# Logs and environment files
*.log
.env
.env.local
.DS_Store
.vscode
